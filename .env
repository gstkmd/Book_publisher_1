# Replace <password> with your actual password
MONGO_URI=mongodb://admin:StrongPassword123@mongo:27017/admin?authSource=admin&tls=false
# Database configuration
DB_NAME=book_publisher

# Security
SECRET_KEY=supersecretkey

# backend
NEXT_PUBLIC_API_URL=https://publisher.connecterp.cloud/api/v1



