# Root Configuration
# ==================

# Deployment Metadata
PROJECT_NAME="Book Publisher"
DOMAIN="publisher.connecterp.cloud"

# Application Services
# ====================

# Next.js Frontend
# For production, this should be https://publisher.connecterp.cloud/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# FastAPI Backend
# ====================

# Security
SECRET_KEY=change_me_in_production
ENCRYPTION_KEY=change_me_to_32_byte_urlsafe_base64_base64

# Database (Production should use Mongo Atlas)
MONGO_URI=mongodb://admin:StrongPassword123@mongo:27017/admin?authSource=admin
DB_NAME=book_publisher

# Cache / Worker
REDIS_PASSWORD=change_me_redis
CELERY_BROKER_URL=redis://:change_me_redis@redis:6379/0

# Storage (e.g. Wasabi/S3)
S3_ENDPOINT_URL=https://s3.wasabisys.com
S3_BUCKET=edu-publishing-bucket
AWS_ACCESS_KEY_ID=change_me
AWS_SECRET_ACCESS_KEY=change_me
AWS_REGION=us-east-1

# CORS Origins (Comma-separated)
BACKEND_CORS_ORIGINS=https://publisher.connecterp.cloud,http://localhost:3000
